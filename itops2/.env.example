# Copy to .env and edit. No inline comments on value lines (pydantic-settings).
# NOTE: variable interpolation does NOT happen inside env_file values —
# write the DB password literally in both DB_PASSWORD and DATABASE_URL.

SECRET_KEY=generate-a-long-random-string
DEBUG=false

DB_PASSWORD=generate-a-strong-password
DATABASE_URL=postgresql+asyncpg://itops2:generate-a-strong-password@db:5432/itops2

BREAKGLASS_USERNAME=admin
BREAKGLASS_PASSWORD=change-me-immediately

CA_CERT_PATH=/certs/step-ca-root.pem
