# ── PostgreSQL ──────────────────────────────────────────────────────────────────
POSTGRES_DB=itops
POSTGRES_USER=itops
POSTGRES_PASSWORD=changeme_strong_password

# ── App ─────────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_with_secrets_token_hex_32
APP_BASE_URL=http://localhost:8000       # Change to your NPM-exposed URL in production
APP_PORT=8000

# ── Authentik OIDC ───────────────────────────────────────────────────────────────
# Your Authentik instance URL (no trailing slash)
AUTHENTIK_BASE_URL=https://authentik.home.internal
# The "slug" of the OAuth2 Provider you create in Authentik
AUTHENTIK_SLUG=itops
# From the Authentik OAuth2/OIDC provider settings
AUTHENTIK_CLIENT_ID=your_client_id_here
AUTHENTIK_CLIENT_SECRET=your_client_secret_here

# ── pgAdmin ──────────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@home.internal
PGADMIN_PASSWORD=changeme_pgadmin_password
PGADMIN_PORT=5050
