# ============================================================
#  Helpdesk — Environment Variables
#  Copy to .env and fill in all required values
# ============================================================

# ---------- Shared DB (must match itops stack) ----------
ITOPS_DB_USER=itops
ITOPS_DB_PASSWORD=CHANGE_ME
ITOPS_DB_NAME=itops

# ---------- App ----------
SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_STRING
APP_BASE_URL=http://192.168.110.50:8001
DEBUG=false

# ---------- Authentik OIDC ----------
# Create an OAuth2/OIDC Provider in Authentik:
#   - Redirect URI: ${APP_BASE_URL}/auth/callback
#   - Grant type: Authorization Code
#   - Client type: Confidential
AUTHENTIK_BASE_URL=https://auth.home.internal
AUTHENTIK_CLIENT_ID=CHANGE_ME
AUTHENTIK_CLIENT_SECRET=CHANGE_ME

# ---------- SMTP ----------
SMTP_HOST=smtp.home.internal
SMTP_PORT=587
SMTP_USER=helpdesk@home.internal
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=helpdesk@home.internal
SMTP_TLS=true
SMTP_STARTTLS=true

# ---------- Helpdesk ----------
# Comma-separated fallback email for new tickets when no tech assigned
HELPDESK_ADMIN_EMAIL=admin@home.internal
# Authentik group names that map to roles
HELPDESK_TECH_GROUP=helpdesk-tech
HELPDESK_ADMIN_GROUP=helpdesk-admin
